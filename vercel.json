{
    "cleanUrls": true,
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!api/|sitemap.xml|robots.txt).*)",
            "destination": "/index.html"
        }
    ]
}